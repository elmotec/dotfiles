[dotfiles]
repository = .  # current directory.
ignore = .git .gitignore .gitmodules
    *.swp dotfiles.py README.rst 
    .unison/ar* .unison/fp* *.bak 
    __pycache__ manage.py test_manage.py *.pyc
    .bash_history .gitconfig .inputrc .ipython .pypirc
    .ssh .vim .viminfo .pylint.d .sqldeveloper .vft*
